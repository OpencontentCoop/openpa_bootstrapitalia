<form class="form" action="{'newsletter/subscribe'|ezurl(no)}" method="get">
    <div class="input-group mb-3">
        <label for="NewsletterInputEmail" class="sr-only">Email address</label>
        <input class="form-control form-control-sm" required="required" id="NewsletterInputEmail" name="email" type="email" placeholder="Indirizzo email">
        <div class="input-group-append">
            <button type="submit" class="btn btn-xs btn-success">Iscriviti</button>
        </div>
    </div>
</form>